#include<iostream>
using namespace std;
int main()
{
    int i=2,n,flag=1,m;
   cout<<"Enter a number to check whether it is prime or not: ";
    cin>>n;
m=n/2;
if(n<=1)
{
    cout<<n<<" is not prime";
}
for(i=2;i<=m;i++)
{
    if(n%i==0)
{
    cout<<n<<" is not prime";
    flag=0;
    break;
}
}
if(flag==1)
{
    cout<<n<<" is prime";
}
return 0;
}
