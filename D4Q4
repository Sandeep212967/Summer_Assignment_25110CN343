#include <iostream>
using namespace std;

int main() {
    int i,temp,sum, n, m, d;

    cout << "Enter starting number: ";
    cin >> n;
    cout << "Enter ending number: ";
    cin >> m;

    cout << "Armstrong numbers are: ";

    for (i = n; i <= m; i++) {
         temp = i;
         sum = 0;

        while (temp > 0) {
         d = temp % 10;
            sum =sum + d * d * d;
            temp = temp / 10;
        }

        if (sum == i) {
            cout << i << " ";
        }
    }

    return 0;
}
