#include<iostream>
using namespace std;
int main()  
{
    int n,reverse=0,d,m;
    cout<<"Enter the number: "; 
    cin>>n;
    m=n;
    while(n>0)
    {
        d = n % 10;
        reverse = reverse * 10 + d;
        n = n / 10;  
    }
    cout<<"Reverse of the number: "<<reverse;
    if(m==reverse)
    {
        cout<<"\nThe number is a palindrome.";
    }
    else
    {
        cout<<"\nThe number is not a palindrome.";
    }
    return 0;
}
