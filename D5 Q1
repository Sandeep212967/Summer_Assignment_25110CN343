#include<iostream>
using namespace std;
int main()
{
    int sum=0,n,m,i;
    cout<<"Enter the number: ";  //n is starting number
    cin>>n;
   m=n/2;
for(i=1;i<=m;i++)  //loop for checking each number in the range
{
    if(n%i==0)  //checking if the number is a factor of n
    {
        sum=sum+i;  //adding the factor to sum
    }
}
    if(sum==n)  //checking if sum of factors is equal to the number
  {

  cout<<n<<" is a perfect number."<<"\n";  //printing the perfect number
  }
  else
  {
      cout<<n<<" is not a perfect number."<<"\n";  //printing the perfect number
  }
  return 0;
}
