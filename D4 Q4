#include<iostream>
using namespace std;
int main(){
    int a,b,x,y,c,gcd,lcm;
    cout<<"Enter first number: ";
    cin>>a;
    cout<<"Enter second number: ";
    cin>>b;
    x=a;
    y=b;
    while(b!=0){
        c=a%b;
        a=b;
        b=c;
    }
    gcd=a;
    lcm=(x*y)/gcd;
    cout<<"LCM is: "<<lcm;
    return 0;
}
